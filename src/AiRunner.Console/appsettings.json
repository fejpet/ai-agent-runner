{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "runner": {
    "root-folder": "/mnt/c/_data/_agents",
    "terminal-multiplexer": "tmux",
    "argument": "new -d -s {{agent-name}}-agent \"cd {{root-folder}}/instances/{{agent-name}}-agent && copilot\"",
    "owner-name": "Peter",
    "agents": [
      {
        "name": "boss",
        "report-to": null,
        "role": "boss"
      }
    ]
  }
}

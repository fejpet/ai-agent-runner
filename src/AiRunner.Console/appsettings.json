{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "runner": {
    "root-folder": "/mnt/c/_data/_agents",
    "agents-folder": "instances",
    "commands": [
      {
        "name": "start",
        "command": "tmux new -d -s {{agent-name}}-agent \"cd {{root-folder}}/instances/{{agent-name}}-agent && copilot\""
      },
      {
        "name": "stop",
        "command": "tmux kill-session -t {{agent-name}}-agent"
      },
      {
        "name": "has-session",
        "command": "tmux has-session -t {{agent-name}}-agent"
      },
      { "name": "list-sessions", "command": "tmux list-sessions" },
      {
        "name": "send-keys",
        "command": "tmux send-keys -t {{agent-name}}-agent:0.0 \"{{command}}\" Enter"
      }
    ],
    "terminal-multiplexer": "tmux",
    "argument": "new -d -s {{agent-name}}-agent \"cd {{root-folder}}/instances/{{agent-name}}-agent && copilot\"",
    "owner-name": "Peter",
    "agents": [
      {
        "name": "boss",
        "report-to": null,
        "role": "boss"
      }
    ]
  }
}
